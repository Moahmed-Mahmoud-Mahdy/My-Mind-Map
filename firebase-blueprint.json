{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "MindMap": {
      "title": "MindMap",
      "description": "Stores a generated mind map",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The mind map's unique ID" },
        "userId": { "type": "string", "description": "The ID of the user who owns this mind map" },
        "title": { "type": "string", "description": "The title of the mind map" },
        "pdfName": { "type": "string", "description": "The name of the PDF file used to generate the mind map" },
        "nodes": { "type": "string", "description": "JSON stringified array of React Flow nodes" },
        "edges": { "type": "string", "description": "JSON stringified array of React Flow edges" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the mind map was created" }
      },
      "required": ["id", "userId", "title", "nodes", "edges", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/mindmaps/{mindmapId}": {
      "schema": { "$ref": "#/entities/MindMap" },
      "description": "Generated mind maps"
    }
  }
}
